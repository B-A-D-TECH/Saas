# Example environment variables for Restaurant-Pos
# Copy to .env and fill values; do NOT commit secrets.

# Server
PORT=4000

# PostgreSQL (either provide DATABASE_URL or the PG_* pieces)
DATABASE_URL=
PG_USER=postgres
PG_PASSWORD=changeme
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=restaurant

# JWT
JWT_SECRET=replace_this_with_a_random_secret

# Optional keys
ADMIN_ACCESS_KEY=changeme
EMPLOYEE_ACCESS_KEY=changeme
