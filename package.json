{
  "name": "restaurant-pos-caisse",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "node ./node_modules/concurrently/dist/bin/concurrently.js -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "node ./node_modules/vite/bin/vite.js",
    "dev:api": "node --watch --import tsx server/index.ts",
    "build": "node ./node_modules/typescript/lib/tsc.js && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "start:api": "node --import tsx server/index.ts"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.12.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.30.4",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^22.13.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-router-dom": "^5.3.3",
    "@types/uuid": "^9.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vite": "^6.0.1"
  }
}
